    reprocess|rp)  cmd_reprocess;;
    compress|cmp)  cmd_compress "${@:2}";;
    docs|docu|documentation)  cmd_docs;;
    tail|log)     _wt_timed=false; cmd_tail;;
    h|help|-h|--help)  _wt_timed=false; cmd_help;;
