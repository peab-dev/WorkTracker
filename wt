case "${1:-help}" in
    s|status)     cmd_status;;
    r|restart)    cmd_restart;;
    start)        cmd_start;;
    stop)         cmd_stop;;
    d|daily)      cmd_agg daily;;
    w|weekly)     cmd_agg weekly;;
