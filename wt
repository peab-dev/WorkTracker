    printf '\033[?25l'  # hide cursor
    printf '\033[2J\033[H'  # clear screen

    # ── ASCII Word Art: WORK:TRACKER (animated line-by-line) ──
    # The colon separates WORK and TRACKER and will blink red later
    local -a art_left=(
        ' █     █  ██████  ██████  █   █ '
        ' █     █  █    █  █    █  █  █  '
        ' █  █  █  █    █  ██████  ███   '
        ' █ █ █ █  █    █  █   █   █  █  '
        '  ██ ██   ██████  █   ██  █   █ '
    )
    local -a art_sep=(
        '  ██  '
        '  ██  '
        '      '
        '  ██  '
        '  ██  '
    )
    local -a art_right=(
        ' ██████ ██████   █████  ██████ █   █ ██████ ██████ '
        '   ██   █    █  █    █  █      █  █  █      █    █ '
        '   ██   ██████  ███████ █      ███   █████  ██████ '
        '   ██   █   █   █    █  █      █  █  █      █   █  '
        '   ██   █   ██  █    █  ██████ █   █ ██████ █   ██ '
    )

    local banner_row=1  # first row of the banner (0-indexed from cursor)
    printf "\n"
    for (( r=0; r<5; r++ )); do
        printf "  ${CYAN}${BOLD}%s${RST}" "${art_left[$r]}"
        printf "${RED}${BOLD}%s${RST}" "${art_sep[$r]}"
        printf "${CYAN}${BOLD}%s${RST}" "${art_right[$r]}"
        printf "\n"
        sleep 0.07
    done
    sleep 0.1

    printf "\n"
    printf "  ${GRAY_L}made in Austria with ${RED}<3${GRAY_L} by ${CYAN}${BOLD}peab.at${RST}  ${GRAY}for mac${RST} \033[38;5;196m${RST}\n"
    printf "\n"
    printf "  ${WHITE}${BOLD}Usage:${RST}  ${CYAN}wt${RST} ${WHITE}<command>${RST}\n"
    printf "\n"

    printf "  ${CYAN}${BOLD}Overview${RST}\n"
    printf "    ${WHITE}${BOLD}status${RST}       ${GRAY_L}Show services, data & reports${RST}        ${ORANGE}wts${RST}\n"
    printf "    ${WHITE}${BOLD}tail${RST}         ${GRAY_L}Follow collector logs live${RST}           ${ORANGE}wtl${RST}\n"
    echo ""

    printf "  ${CYAN}${BOLD}Collector${RST}\n"
    printf "    ${WHITE}${BOLD}restart${RST}      ${GRAY_L}Restart collector daemon${RST}             ${ORANGE}wtr${RST}\n"
    printf "    ${WHITE}${BOLD}start${RST}        ${GRAY_L}Start collector${RST}\n"
    printf "    ${WHITE}${BOLD}stop${RST}         ${GRAY_L}Stop collector${RST}\n"
    echo ""

    printf "  ${CYAN}${BOLD}Aggregator${RST}\n"
    printf "    ${WHITE}${BOLD}daily${RST}        ${GRAY_L}Run daily aggregation${RST}                ${ORANGE}wtd${RST}\n"
    printf "    ${WHITE}${BOLD}weekly${RST}       ${GRAY_L}Run weekly aggregation${RST}               ${ORANGE}wtw${RST}\n"
    printf "    ${WHITE}${BOLD}monthly${RST}      ${GRAY_L}Run monthly aggregation${RST}              ${ORANGE}wtm${RST}\n"
    echo ""

    printf "  ${CYAN}${BOLD}Dashboard${RST}\n"
    printf "    ${WHITE}${BOLD}dash${RST}         ${GRAY_L}Open terminal dashboard${RST}\n"
    printf "    ${WHITE}${BOLD}web${RST}          ${GRAY_L}Start web dashboard (port 7880)${RST}\n"
    printf "    ${WHITE}${BOLD}menubar${RST}      ${GRAY_L}Start macOS menubar widget${RST}              ${ORANGE}wtmb${RST}\n"
    printf "    ${WHITE}${BOLD}docs${RST}         ${GRAY_L}Open documentation in browser${RST}           ${ORANGE}wtdocs${RST}\n"
    echo ""

    printf "  ${GRAY_L}wtrl${RST} ${GRAY}= reload shell (activate aliases)${RST}\n"
    echo ""

    # ── Blinking colon (cyan/red) + Rainbow Apple ──
    trap 'printf "\033[?25h\033[0m"; stty echo 2>/dev/null; exit 0' INT
    stty -echo 2>/dev/null

    local sep_col=34   # column where the colon block starts (2 indent + 32 chars WORK block)
    local apple_row=6  # row of "made in Austria..." line
    local apple_col=57 # column of the Apple logo after "for mac "
    local -a colon_on=('  ██  ' '  ██  ' '      ' '  ██  ' '  ██  ')
    local colon_colors=("${RED}" "${CYAN}")
    local rainbow=('\033[38;5;196m' '\033[38;5;208m' '\033[38;5;226m' '\033[38;5;46m' '\033[38;5;33m' '\033[38;5;93m')
    local ci=0
    local ai=0

    while true; do
        local cc="${colon_colors[$ci]}"
        local ac="${rainbow[$ai]}"
        # redraw colon block in current color
        for (( r=0; r<5; r++ )); do
            tput cup $(( banner_row + r )) $sep_col
            printf "${cc}${BOLD}%s${RST}" "${colon_on[$r]}"
        done
        # rainbow apple
        tput cup $apple_row $apple_col
        printf "${ac}${RST}"

        ci=$(( (ci + 1) % 2 ))
        ai=$(( (ai + 1) % ${#rainbow[@]} ))

        if read -t 1 -n 1 -s 2>/dev/null; then
            break
        fi
    done

    stty echo 2>/dev/null
    printf '\033[?25h\033[0m'
    echo ""
}

cmd_start() {
    header "COLLECTOR START"
    msg_info "Loading and starting collector..."
    launchctl load "$PLIST_COL" 2>/dev/null || true
    launchctl start "$LABEL_COL"
    sleep 1

    local result
    result=$(svc_status "$LABEL_COL")
    local state pid
    IFS='|' read -r state pid _ <<< "$result"

    if [[ "$state" == "running" ]]; then
        msg_ok "Collector running — PID ${BOLD}${pid}${RST}"
    else
        msg_warn "Collector loaded, waiting to start"
    fi
    echo ""
}

cmd_stop() {
    header "COLLECTOR STOP"
    msg_info "Stopping collector..."
    launchctl stop "$LABEL_COL" 2>/dev/null || true
    launchctl unload "$PLIST_COL" 2>/dev/null || true
    msg_ok "Collector stopped"
    echo ""
}

cmd_docs() {
    local docs_file="$BASE/docs/index.html"
    if [[ -f "$docs_file" ]]; then
        msg_info "Opening documentation..."
        open "$docs_file"
    else
        msg_err "Documentation not found: ${WHITE}$docs_file${RST}"
    fi
}

