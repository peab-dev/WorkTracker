        _wt_timed=false
        printf "${RED}Unknown command: ${WHITE}${BOLD}%s${RST}\n" "$1"
        printf "${GRAY_L}Run ${WHITE}wt help${GRAY_L} for usage info${RST}\n"
        exit 1
        ;;
